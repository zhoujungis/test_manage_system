# =====================================================================
# 测试管理系统 — 环境变量模板（copy 为 .env 后填入真实值）
# =====================================================================
# 注意：
#   - .env 在 .gitignore 中；本文件是模板，可以提交。
#   - 生产环境必须设置 DJANGO_ENV=production —— 此时占位符 SECRET_KEY
#     / DEBUG=True / 弱 DB 密码都会让 Django 拒绝启动。
#   - 生成强随机密钥：python -c "import secrets; print(secrets.token_urlsafe(50))"
# =====================================================================

# 部署环境标记；不设置或设为 development / staging 走宽松校验。
# 生产环境必须设为 production。
DJANGO_ENV=development

# Django
# 占位符会被生产模式拒绝。开发环境若不设置可使用 python manage.py runserver 默认配置。
DJANGO_SECRET_KEY=replace-me-with-python-secrets-token-urlsafe-50
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_STATIC_ROOT=

# Cache
# 生产必须 redis —— file/locmem 在多 worker 下不可靠，throttle 形同虚设。
# 留空走 file cache（仅 dev 可用）。
DJANGO_CACHE_BACKEND=
# DJANGO_REDIS_URL=redis://127.0.0.1:6379/1

# Database
DB_NAME=testmanager
DB_USER=testmanager
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Email (optional - SMTP config)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mxhichina.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=